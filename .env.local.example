# ============================================================
# VBetreut ERP – Umgebungsvariablen
# ============================================================
# WICHTIG: Diese Datei heißt ".env.local" (mit Punkt am Anfang)
# Sie liegt im Hauptverzeichnis von vbetreut-erp/
# NIEMALS in Git committen — steht bereits in .gitignore
# ============================================================


# ── Anthropic API (für Leselotte, Doris, Dokument-KI) ────────
#
# So bekommen Sie den Key:
# 1. https://console.anthropic.com aufrufen
# 2. Kostenloses Konto anlegen (oder einloggen)
# 3. Links auf "API Keys" klicken
# 4. "Create Key" → Key kopieren
# 5. Hier einfügen (ersetzt das sk-ant-... unten):
#
# Kosten: ca. $0.003 pro Leselotte/Doris-Anfrage (sehr günstig)
# Gratis-Guthaben für neue Accounts: $5
#
ANTHROPIC_API_KEY=sk-ant-HIER-IHREN-KEY-EINFÜGEN


# ── Supabase (nur für Mehrbenutzerbetrieb nötig) ─────────────
#
# Für lokales Testen NICHT erforderlich — einfach leer lassen.
# Das ERP speichert dann alles im Browser (localStorage).
#
# Für echten Betrieb mit mehreren Benutzern:
# 1. https://supabase.com → Kostenloses Projekt anlegen
# 2. Settings → API → URL und anon key kopieren
#
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=


# ── App-Einstellungen (optional) ─────────────────────────────
NEXT_PUBLIC_APP_NAME=VBetreut ERP
# NEXT_PUBLIC_APP_URL=https://erp.vbetreut.at
