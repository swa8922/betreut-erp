# VBetreut CarePlus ERP — Umgebungsvariablen
# Kopieren nach .env.local und anpassen

# ─── Datenbank-Modus ───────────────────────────────────────────────────────
# "supabase"  → Supabase (cloud, Standard)
# "local"     → Lokale PostgreSQL oder SQLite
# "memory"    → Nur im Arbeitsspeicher (für Tests)
NEXT_PUBLIC_DB_MODE=supabase

# ─── Supabase (Produktion) ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://eiopeyklxugcnvxfktkz.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImVpb3BleWtseHVnY252eGZrdGt6Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQ4MDAzMjgsImV4cCI6MjA5MDM3NjMyOH0.OqVCBmeoEfaKezcWVkL2UetD165LRJn8Ub8qb9tUCsA

# ─── Für lokalen Betrieb (Alternative zu Supabase) ─────────────────────────
# LOCAL_DB_PATH=./data/vbetreut.db          # SQLite-Pfad
# DATABASE_URL=postgresql://user:pass@localhost:5432/vbetreut  # PostgreSQL

# ─── KI-Features ──────────────────────────────────────────────────────────
# Anthropic API Key für Doris, Leselotte, Alfred, Ausweis-Erkennung
ANTHROPIC_API_KEY=sk-ant-...

# ─── Datenbank wechseln ────────────────────────────────────────────────────
# Zu einer anderen Supabase-Instanz:
#   1. Neues Projekt in Supabase anlegen
#   2. Migrations aus /supabase/migrations/ ausführen
#   3. NEXT_PUBLIC_SUPABASE_URL und NEXT_PUBLIC_SUPABASE_ANON_KEY ersetzen
#   4. Neu deployen
#
# Zu lokalem Server:
#   1. NEXT_PUBLIC_DB_MODE=local setzen
#   2. PostgreSQL/SQLite installieren
#   3. DATABASE_URL setzen
#   4. npm run db:migrate ausführen
#   5. npm run dev
